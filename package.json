{
  "name": "aichat",
  "description": "AI Chat — a fully client-side Expo app for chatting with many LLM providers using your own API keys (BYOK).",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "eas": "eas",
    "build:ios": "eas build --platform ios --auto-submit",
    "expo": "expo",
    "fix:dependencies": "expo install --fix"
  },
  "main": "expo-router/entry",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/cerebras": "^2.0.57",
    "@ai-sdk/cohere": "^3.0.39",
    "@ai-sdk/deepinfra": "^2.0.55",
    "@ai-sdk/deepseek": "^2.0.39",
    "@ai-sdk/fireworks": "^2.0.57",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/mistral": "^3.0.40",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/perplexity": "^3.0.36",
    "@ai-sdk/react": "^3.0.208",
    "@ai-sdk/togetherai": "^2.0.56",
    "@ai-sdk/xai": "^3.0.96",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@ungap/structured-clone": "^1.3.1",
    "ai": "^6.0.206",
    "expo": "~56.0.12",
    "expo-application": "56.0.3",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-document-picker": "56.0.4",
    "expo-font": "~56.0.7",
    "expo-image": "~56.0.11",
    "expo-image-picker": "56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-secure-store": "56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-store-review": "56.0.3",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-code-highlighter": "^1.3.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-get-random-values": "^2.0.0",
    "react-native-marked": "^8.1.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "react-syntax-highlighter": "^15.6.6"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "eas-cli": "^20.2.0",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@ai-sdk/.*|ai))"
    ],
    "moduleNameMapper": {
      "\\.css$": "<rootDir>/jest/css-stub.js",
      "^react-syntax-highlighter/dist/esm/styles/hljs$": "<rootDir>/jest/empty-module.js",
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/app/**",
      "!src/**/*.test.{ts,tsx}",
      "!src/**/*.d.ts"
    ]
  }
}
